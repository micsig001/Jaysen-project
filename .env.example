# ============================================
# 企业级任务协同管理系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并修改相应配置

# --------------------------------------------
# 服务器配置
# --------------------------------------------
SERVER_PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=5173
SPRING_PROFILE=dev

# --------------------------------------------
# 前端 - Token AES 加密密钥（必填，至少 32 字符）
# 生成方式：openssl rand -base64 32
# --------------------------------------------
VITE_TOKEN_SECRET=change-me-32-chars-minimum-secret-key-here

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=task_system
DB_USERNAME=root
DB_PASSWORD=change-me-in-production

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# [必填] Redis密码,生产环境请使用强密码
REDIS_PASSWORD=changeme

# --------------------------------------------
# JWT 配置
# --------------------------------------------
# [必填] JWT密钥,至少32字符,建议使用 openssl rand -base64 32 生成
JWT_SECRET=

# --------------------------------------------
# 企业微信配置
# --------------------------------------------
WEWORK_CORP_ID=your-corp-id
WEWORK_AGENT_ID=your-agent-id
WEWORK_SECRET=your-secret
WEWORK_MESSAGE_ENABLED=true

# --------------------------------------------
# 敏感数据脱敏配置
# --------------------------------------------
SENSITIVE_DATA_ENABLED=true

# --------------------------------------------
# 对象存储配置
# --------------------------------------------
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# MinIO 配置（当 STORAGE_TYPE=minio 时使用）
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=task-files

# 阿里云 OSS 配置（当 STORAGE_TYPE=aliyun-oss 时使用）
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=task-files-prod
